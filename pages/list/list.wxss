.list-page {
  padding-bottom: 80px;
  background-color: #F5F0E6;
  min-height: 100vh;
  position: relative;
}

/* Tab切换 */
.tab-container {
  display: flex;
  background-color: #FFF9F3;
  padding: 16px 16px;
  gap: 12px;
  border-bottom: 1px solid rgba(167, 72, 48, 0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: 14px;
  color: #6B5B4F;
  border-radius: 12px;
  background-color: #F5F0E6;
  border: 1px solid rgba(167, 72, 48, 0.12);
  transition: all 0.3s ease;
}

.tab.active {
  background-color: #A74830;
  color: #FFF9F3;
  font-weight: 500;
  border: 1px solid #A74830;
}

/* 状态筛选 */
.status-filter {
  display: flex;
  background-color: #FFF9F3;
  padding: 0 16px 12px 16px;
  gap: 8px;
  overflow-x: auto;
  white-space: nowrap;
}

.status-item {
  padding: 6px 12px;
  font-size: 13px;
  color: #6B5B4F;
  border-radius: 12px;
  background-color: #F5F0E6;
  flex-shrink: 0;
  border: 1px solid rgba(167, 72, 48, 0.12);
  transition: all 0.3s ease;
}

.status-item.active {
  background-color: #A74830;
  color: #FFF9F3;
  border: 1px solid #A74830;
}

/* 问题列表 */
.issue-list {
  padding: 16px 16px 8px 16px;
}

.issue-card {
  background-color: #FFF9F3;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid rgba(167, 72, 48, 0.08);
  box-shadow: 0 2px 12px rgba(167, 72, 48, 0.04);
  transition: all 0.3s ease;
}

.issue-card:active {
  transform: translateY(1px);
  box-shadow: 0 1px 8px rgba(167, 72, 48, 0.06);
}

.issue-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.issue-category {
  font-size: 13px;
  color: #6B5B4F;
  letter-spacing: 0.5px;
}

.issue-status {
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  letter-spacing: 0.3px;
}

.issue-description {
  font-size: 14px;
  color: #3D3028;
  line-height: 1.6;
  margin-bottom: 12px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.issue-images {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.issue-image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  object-fit: cover;
  border: 1px solid rgba(167, 72, 48, 0.12);
}

.issue-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 11px;
  color: #9B8B7A;
}

.issue-location {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12px;
}

.issue-time {
  flex-shrink: 0;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 20px 0;
  font-size: 13px;
  color: #9B8B7A;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 20px 0;
  font-size: 13px;
  color: #9B8B7A;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80px 0;
  font-size: 14px;
  color: #9B8B7A;
}

/* 底部导航 */
.bottom-nav {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  width: 100%;
  height: 64px;
  background-color: #FFF9F3;
  display: flex;
  box-shadow: 0 -2px 16px rgba(167, 72, 48, 0.06);
  border-top: 1px solid rgba(167, 72, 48, 0.08);
  z-index: 9999;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  color: #9B8B7A;
  position: relative;
  padding: 8px 0;
}

.nav-item.active {
  color: #A74830;
}

.nav-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #F5F0E6;
  margin-bottom: 4px;
  transition: all 0.3s ease;
}

.nav-item.active .nav-icon {
  background-color: #A74830;
}

.icon-text {
  font-size: 18px;
  line-height: 1;
}

.nav-item.active .icon-text {
  color: #FFF9F3;
}

.nav-text {
  font-size: 11px;
  letter-spacing: 0.5px;
  margin-top: 2px;
}
