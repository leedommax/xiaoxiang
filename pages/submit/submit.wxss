.submit-page {
  padding: 0 16px;
  padding-bottom: 140px;
  background-color: #F5F0E6;
  min-height: 100vh;
  position: relative;
}

.form-item {
  background-color: #FFF9F3;
  border-radius: 10px;
  padding: 16px;
  margin-bottom: 8px;
  margin-top: 16px;
  border: 1px solid rgba(167, 72, 48, 0.08);
  box-shadow: 0 2px 12px rgba(167, 72, 48, 0.04);
}

.section-title {
  font-size: 15px;
  font-weight: 500;
  color: #3D3028;
  margin-bottom: 12px;
  letter-spacing: 0.5px;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.category-item {
  padding: 8px 16px;
  border-radius: 12px;
  background-color: #F5F0E6;
  color: #6B5B4F;
  font-size: 13px;
  border: 1px solid rgba(167, 72, 48, 0.12);
  transition: all 0.3s ease;
}

.category-item.active {
  background-color: #A74830;
  color: #FFF9F3;
  border: 1px solid #A74830;
}

/* 图片上传 */
.uploader-container {
  width: 100%;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.image-item {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid rgba(167, 72, 48, 0.12);
}

.image-item image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 20px;
  height: 20px;
  background-color: rgba(167, 72, 48, 0.7);
  color: #FFF9F3;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 8px 0 8px;
  font-size: 16px;
}

.upload-btn {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  background-color: #F5F0E6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px dashed rgba(167, 72, 48, 0.24);
}

.upload-btn .plus {
  font-size: 32px;
  color: #A74830;
  line-height: 1;
}

.upload-btn .text {
  font-size: 11px;
  color: #9B8B7A;
  margin-top: 4px;
}

/* 紧急程度 */
.urgency-list {
  display: flex;
  gap: 12px;
}

.urgency-item {
  flex: 1;
  padding: 10px 0;
  text-align: center;
  border-radius: 12px;
  background-color: #F5F0E6;
  color: #6B5B4F;
  font-size: 14px;
  border: 1px solid rgba(167, 72, 48, 0.12);
  transition: all 0.3s ease;
}

.urgency-item.active {
  background-color: #A74830;
  color: #FFF9F3;
  font-weight: 500;
  border: 1px solid #A74830;
}

/* 文本域和输入框 */
.description-input {
  width: 100%;
  min-height: 120px;
  padding: 12px;
  background-color: #F5F0E6;
  border-radius: 10px;
  font-size: 14px;
  line-height: 1.6;
  color: #3D3028;
  border: 1px solid rgba(167, 72, 48, 0.12);
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 11px;
  color: #9B8B7A;
  margin-top: 8px;
}

.location-input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  background-color: #F5F0E6;
  border-radius: 10px;
  font-size: 14px;
  color: #3D3028;
  border: 1px solid rgba(167, 72, 48, 0.12);
  box-sizing: border-box;
}

/* 分期选择 */
.phase-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 12px;
}

.phase-item {
  padding: 8px 16px;
  border-radius: 12px;
  background-color: #F5F0E6;
  color: #6B5B4F;
  font-size: 13px;
  border: 1px solid rgba(167, 72, 48, 0.12);
  transition: all 0.3s ease;
}

.phase-item.active {
  background-color: #A74830;
  color: #FFF9F3;
  border: 1px solid #A74830;
}

.building-input {
  margin-bottom: 10px;
}

/* 提交按钮 */
.submit-btn-container {
  margin-top: 24px;
}

.submit-btn {
  width: 100%;
  height: 44px;
  background: linear-gradient(135deg, #A74830 0%, #8B3D28 100%);
  color: #FFF9F3;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 500;
  border: none;
  box-shadow: 0 4px 16px rgba(167, 72, 48, 0.24);
  letter-spacing: 1px;
}

.submit-btn:active {
  opacity: 0.85;
  transform: translateY(1px);
}

/* 底部导航 */
.bottom-nav {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  width: 100%;
  height: 64px;
  background-color: #FFF9F3;
  display: flex;
  box-shadow: 0 -2px 16px rgba(167, 72, 48, 0.06);
  border-top: 1px solid rgba(167, 72, 48, 0.08);
  z-index: 9999;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  color: #9B8B7A;
  position: relative;
  padding: 8px 0;
}

.nav-item.active {
  color: #A74830;
}

.nav-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #F5F0E6;
  margin-bottom: 4px;
  transition: all 0.3s ease;
}

.nav-item.active .nav-icon {
  background-color: #A74830;
}

.icon-text {
  font-size: 18px;
  line-height: 1;
}

.nav-item.active .icon-text {
  color: #FFF9F3;
}

.nav-text {
  font-size: 11px;
  letter-spacing: 0.5px;
  margin-top: 2px;
}
